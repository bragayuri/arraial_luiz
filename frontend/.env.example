# URL do backend GraphQL (Apollo Server)
# Em dev: aponta para localhost
# Em prod: URL do Render (ex: https://arraiau-backend.onrender.com)
VITE_GRAPHQL_URI=http://localhost:4000

# Opcional: UUID do convidado usado no redirect de /. Default = mesmo do npm run seed no backend.
# VITE_DEMO_GUEST_ID=00000000-0000-0000-0000-000000000001
